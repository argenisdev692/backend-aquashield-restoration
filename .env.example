# ============================================================
#  Vidula Backend — .env template
#  Copy this file to .env and fill the real values (NEVER commit .env).
#  Real local values can be kept in env-note.txt (gitignored notebook).
# ============================================================

# ---- App ----
APP_URL=https://api.yourdomain.com
APP_ENV=development
NODE_ENV=development
PORT=8080
APP_PORT=8080
HOST=0.0.0.0
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:8080
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ---- Redis (used by docker-compose.yml and the app at runtime) ----
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ---- Database (Supabase Postgres) ----
# Use the Supabase SESSION pooler on port 5432 — supports prepared statements,
# DDL (Prisma migrate / db push) AND application runtime via @prisma/adapter-pg.
# The Transaction pooler on port 6543 does NOT support DDL, so we avoid it.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# ---- Supabase (REST / Auth APIs — used by future modules, not by Prisma) ----
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ---- Auth / JWT ----
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
LOGIN_OTP_TTL_SECONDS=600
PASSWORD_RESET_TOKEN_TTL_SECONDS=900
BCRYPT_ROUNDS=10
# Password lifetime in days — 0 disables expiry
PASSWORD_EXPIRES_DAYS=90

# ---- Frontend / Email links ----
FRONTEND_APP_URL=https://app.example.com
PASSWORD_RESET_PATH=/auth/password/reset
INVITE_REDIRECT_URL=https://app.example.com/auth/accept-invite

# ---- Email (Resend) ----
EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@example.com
RESEND_FROM_NAME=Vidula

# ---- Object storage (Cloudflare R2) ----
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DEFAULT_REGION=auto
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
R2_ENDPOINT=
R2_URL=
R2_USE_PATH_STYLE_ENDPOINT=false

# ---- Product packages storage prefix ----
PRODUCT_PACKAGE_STORAGE_DISK=r2
PRODUCT_PACKAGE_STORAGE_DIRECTORY=ai/product-packages

# ---- AI providers ----
AI_DEFAULT_PROVIDER=anthropic
AI_DEFAULT_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_VERSION=2023-06-01

# ---- Tavily (research / web search) ----
TAVILY_API_KEY=
TAVILY_SEARCH_URL=https://api.tavily.com/search
TAVILY_SEARCH_DEPTH=advanced
TAVILY_MAX_RESULTS=5

# ---- Replicate (image generation) ----
REPLICATE_API_TOKEN=
REPLICATE_BASE_URL=https://api.replicate.com/v1
REPLICATE_IMAGE_MODEL=black-forest-labs/flux-2-pro
REPLICATE_IMAGE_ASPECT_RATIO=16:9
REPLICATE_IMAGE_OUTPUT_FORMAT=webp
REPLICATE_IMAGE_OUTPUT_QUALITY=85
REPLICATE_IMAGE_SAFETY_TOLERANCE=2
REPLICATE_IMAGE_PROMPT_UPSAMPLING=true
REPLICATE_WAIT_SECONDS=25
REPLICATE_STORAGE_DISK=r2
REPLICATE_STORAGE_DIRECTORY=ai/campaigns
REPLICATE_STORAGE_DIRECTORY_POSTS=ai/posts

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
