{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "sync:ai": "node scripts/sync-claude-windsurf.mjs --write",
    "check:ai-sync": "node scripts/sync-claude-windsurf.mjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:generate": "prisma generate",
    "db:bootstrap": "prisma db execute --file prisma/bootstrap.sql",
    "db:push": "prisma db push",
    "db:post": "prisma db execute --file prisma/post-tables.sql",
    "db:seed": "prisma db seed",
    "db:setup": "npm run db:bootstrap && npm run db:push && npm run db:post && npm run db:seed",
    "db:studio": "prisma studio",
    "api:export": "tsx scripts/export-openapi.ts",
    "api:generate": "orval",
    "api:sync": "npm run api:export && npm run api:generate"
  },
