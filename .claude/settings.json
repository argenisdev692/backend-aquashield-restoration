{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test*)",
      "Bash(npm install)",
      "Bash(npm run db:migrate)",
      "Bash(npm run db:generate)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(npx nest *)",
      "Bash(npx prisma generate*)",
      "Bash(npx prisma db push*)",
      "Bash(npx prisma db seed*)",
      "Bash(npx prisma db execute*)",
      "Bash(npx prisma format*)",
      "Bash(npx prisma validate*)",
      "Bash(npx prisma studio*)",
      "Bash(npx jest*)",
      "Bash(npx tsc*)",
      "Bash(npx eslint*)",
      "Read",
      "Edit",
      "Write",
      "Grep",
      "Glob"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(git reset*)",
      "Bash(rm *)",
      "Bash(npx prisma migrate*)",
      "Bash(npx prisma migrate reset*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(rm -rf /*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/secrets/**)"
    ]
  },
  "env": {
    "NODE_ENV": "development",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1"
  },
  "mcpServers": {
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "c:\\Users\\Lenovo\\Documents\\PROYECTOS\\VIDULA\\backend"]
    },
    "postgres": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres"],
      "env": {
        "POSTGRES_CONNECTION_STRING": "${DATABASE_URL}"
      }
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_TOKEN}"
      }
    },
    "brave-search": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[hook] file modified'"
          }
        ]
      }
    ]
  }
}
