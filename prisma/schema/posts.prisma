// ============================================================
//  Post — blog post entries
//  - id          : UUID v7 generated by the DB function `uuid_generate_v7()`
//  - updatedAt   : managed by DB trigger; we DO NOT declare `@updatedAt`
//  - deletedAt   : soft-delete tombstone — queries must filter `deletedAt: null`
// ============================================================

enum PostStatus {
  draft
  published
  scheduled

  @@map("post_status")
}

model Post {
  id              String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  postTitle       String      @map("post_title") @db.VarChar(255)
  postTitleSlug   String      @unique @map("post_title_slug") @db.VarChar(255)
  postContent     String      @map("post_content") @db.Text
  postExcerpt     String?     @map("post_excerpt") @db.VarChar(500)
  postCoverImage  String?     @map("post_cover_image") @db.VarChar(2048)
  metaTitle       String?     @map("meta_title") @db.VarChar(255)
  metaDescription String?     @map("meta_description") @db.VarChar(500)
  metaKeywords    String?     @map("meta_keywords") @db.VarChar(255)
  categoryId      String?     @map("category_id") @db.Uuid
  userId          String?     @map("user_id") @db.Uuid
  postStatus      PostStatus  @default(draft) @map("post_status")
  scheduledAt     DateTime?   @map("scheduled_at") @db.Timestamp(6)
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime    @default(now()) @map("updated_at") @db.Timestamp(6)
  deletedAt       DateTime?   @map("deleted_at") @db.Timestamp(6)

  category        BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([postStatus, createdAt], map: "idx_posts_status_created_at")
  @@index([categoryId, createdAt], map: "idx_posts_category_created_at")
  @@index([deletedAt], map: "idx_posts_deleted_at")
  @@map("posts")
}
