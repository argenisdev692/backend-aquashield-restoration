// ============================================================
//  User — auth identity + profile
//  - id          : UUID v7 generated by the DB function `uuid_generate_v7()`
//                  (defined in prisma/bootstrap.sql, must run BEFORE `db push`).
//  - updatedAt   : managed by DB trigger `set_updated_at_users`; we DO NOT
//                  declare `@updatedAt` so Prisma does not fight the trigger.
//  - deletedAt   : soft-delete tombstone — queries must filter `deletedAt: null`.
// ============================================================

model User {
  id                 String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  name               String    @db.VarChar(255)
  lastName           String?   @map("last_name") @db.VarChar(255)
  username           String?   @unique @db.VarChar(255)
  email              String    @unique @db.VarChar(255)
  emailVerifiedAt    DateTime? @map("email_verified_at") @db.Timestamp(6)
  password           String?   @db.VarChar(255)
  phone              String?   @db.VarChar(20)
  dateOfBirth        DateTime? @map("date_of_birth") @db.Date
  address            String?   @db.VarChar(255)
  address2           String?   @map("address_2") @db.VarChar(255)
  zipCode            String?   @map("zip_code") @db.VarChar(20)
  city               String?   @db.VarChar(100)
  state              String?   @db.VarChar(100)
  country            String?   @db.VarChar(100)
  gender             String?   @db.VarChar(20)
  profilePhotoPath   String?   @map("profile_photo_path") @db.VarChar(2048)
  latitude           Float?    @db.DoublePrecision
  longitude          Float?    @db.DoublePrecision
  termsAndConditions Boolean   @default(false) @map("terms_and_conditions")
  totpSecret           String?   @map("totp_secret") @db.VarChar(255)
  totpEnabled          Boolean   @default(false) @map("totp_enabled")
  googleId             String?   @unique @map("google_id") @db.VarChar(255)
  passwordConfirmedAt  DateTime? @map("password_confirmed_at") @db.Timestamp(6)
  mustChangePassword   Boolean   @default(false) @map("must_change_password")
  passwordExpiresAt    DateTime? @map("password_expires_at") @db.Timestamp(6)
  passwordChangedAt    DateTime? @map("password_changed_at") @db.Timestamp(6)
  // Account lockout: when set and in the future, login attempts are rejected
  // regardless of credentials. Cleared on successful credential check or
  // manual unlock. Bumped to now+15min after FAILED_LOGIN_LOCKOUT_THRESHOLD
  // (10) consecutive failures within FAILED_LOGIN_WINDOW_SECONDS.
  lockedUntil          DateTime? @map("locked_until") @db.Timestamp(6)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt            DateTime  @default(now()) @map("updated_at") @db.Timestamp(6)
  deletedAt            DateTime? @map("deleted_at") @db.Timestamp(6)

  // Relations
  roles                UserRole[]
  permissions          UserPermission[]
  rolesAssignedByMe    UserRole[]            @relation("UserRoleAssignedBy")
  permsAssignedByMe    UserPermission[]      @relation("UserPermissionAssignedBy")
  company              CompanyData?
  otpCodes             OtpCode[]
  authSessions         AuthSession[]
  passwordResetTokens  PasswordResetToken[]
  passwordSetupTokens  PasswordSetupToken[]
  blogCategories       BlogCategory[]
  passwordHistory      PasswordHistory[]
  backupCodes          BackupCode[]
  trustedDevices       TrustedDevice[]

  @@index([email], map: "idx_users_email")
  @@index([deletedAt], map: "idx_users_deleted_at")
  @@map("users")
}
