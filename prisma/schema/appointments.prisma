// ============================================================
//  Appointment — sales lead capture (CRM)
//  - statusLead   : nullable enum (`status_lead`)
//  - followUpCalls: arbitrary JSONB array
//  - updatedAt managed by `set_updated_at_appointments` trigger.
// ============================================================

enum StatusLead {
  New
  Called
  Pending
  Declined

  @@map("status_lead")
}

enum InspectionStatus {
  Confirmed
  Completed
  Pending
  Declined

  @@map("inspection_status")
}

enum LeadSource {
  Website
  FacebookAds @map("Facebook Ads")
  Reference
  RetellAI    @map("Retell AI")

  @@map("lead_source")
}

model Appointment {
  id               String      @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  firstName        String      @map("first_name") @db.VarChar(255)
  lastName         String      @map("last_name") @db.VarChar(255)
  phone            String      @db.VarChar(20)
  email            String?     @db.VarChar(255)
  address          String      @db.VarChar(255)
  address2         String?     @map("address_2") @db.VarChar(255)
  city             String      @db.VarChar(100)
  state            String      @db.VarChar(100)
  zipcode          String      @db.VarChar(20)
  country          String      @db.VarChar(100)
  insuranceProperty Boolean    @default(false) @map("insurance_property")
  message          String?
  smsConsent       Boolean     @default(false) @map("sms_consent")
  registrationDate DateTime?   @map("registration_date") @db.Timestamp(6)
  inspectionDate   DateTime?   @map("inspection_date") @db.Date
  inspectionTime   DateTime?   @map("inspection_time") @db.Time(6)
  inspectionStatus InspectionStatus? @map("inspection_status")
  statusLead       StatusLead? @map("status_lead")
  leadSource       LeadSource? @map("lead_source")
  followUpCalls    Json?       @map("follow_up_calls") @db.JsonB
  notes            String?
  owner            String?     @db.VarChar(255)
  damageDetail     String?     @map("damage_detail")
  intentToClaim    Boolean?    @map("intent_to_claim")
  followUpDate     DateTime?   @map("follow_up_date") @db.Date
  additionalNote   String?     @map("additional_note")
  latitude         Float?      @db.DoublePrecision
  longitude        Float?      @db.DoublePrecision
  readed           Boolean     @default(false)
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime    @default(now()) @map("updated_at") @db.Timestamp(6)
  deletedAt        DateTime?   @map("deleted_at") @db.Timestamp(6)

  @@index([statusLead], map: "idx_appointments_status_lead")
  @@index([inspectionStatus], map: "idx_appointments_inspection_status")
  @@index([leadSource], map: "idx_appointments_lead_source")
  @@index([deletedAt], map: "idx_appointments_deleted_at")
  @@index([readed], map: "idx_appointments_readed")
  @@unique([email], name: "idx_appointments_email_unique", where: { deletedAt: null })
  @@map("appointments")
}
