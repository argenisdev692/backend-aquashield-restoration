// ============================================================
//  DatabaseBackup — automated pg_dump snapshots uploaded to R2
//  - id          : UUID v7 generated by the DB function `uuid_generate_v7()`
//  - status      : PENDING (initial) → COMPLETED | FAILED (terminal)
//  - objectKey   : R2 path (e.g. backups/2026/05/24/<id>.dump) — nullable
//                  until the upload succeeds
//  - sizeBytes   : populated on COMPLETED
//  - checksum    : sha256 hex digest of the dump — integrity audit trail
//  - triggeredBy : SCHEDULER (daily cron) or MANUAL (admin via API)
//  - actorId     : NULL for SCHEDULER runs, JWT user id for MANUAL
//  - error       : truncated error message on FAILED
//
//  Append-only: rows transition PENDING → terminal exactly once, then are
//  immutable until the retention listener deletes them.
// ============================================================

enum DatabaseBackupStatus {
  PENDING
  COMPLETED
  FAILED

  @@map("database_backup_status")
}

enum DatabaseBackupTrigger {
  SCHEDULER
  MANUAL

  @@map("database_backup_trigger")
}

model DatabaseBackup {
  id          String                @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  objectKey   String?               @map("object_key") @db.VarChar(512)
  sizeBytes   BigInt?               @map("size_bytes")
  checksum    String?               @db.VarChar(64)
  status      DatabaseBackupStatus  @default(PENDING)
  triggeredBy DatabaseBackupTrigger @map("triggered_by")
  actorId     String?               @map("actor_id") @db.Uuid
  error       String?               @db.Text
  startedAt   DateTime              @default(now()) @map("started_at") @db.Timestamp(6)
  completedAt DateTime?             @map("completed_at") @db.Timestamp(6)
  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([createdAt(sort: Desc)], map: "idx_database_backups_created_at")
  @@index([status], map: "idx_database_backups_status")
  @@map("database_backups")
}
