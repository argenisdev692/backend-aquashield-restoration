// ============================================================
//  BlogCategory — blog post categories
//  - id          : UUID v7 generated by the DB function `uuid_generate_v7()`
//  - updatedAt   : managed by DB trigger; we DO NOT declare `@updatedAt`
//  - deletedAt   : soft-delete tombstone — queries must filter `deletedAt: null`
// ============================================================

model BlogCategory {
  id          String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  name        String?   @map("blog_category_name") @db.VarChar(255)
  description String?   @map("blog_category_description") @db.VarChar(255)
  image       String?   @map("blog_category_image") @db.VarChar(255)
  userId      String    @map("user_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamp(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name], map: "uq_blog_categories_user_name")
  @@index([deletedAt], map: "idx_blog_categories_deleted_at")
  @@map("blog_categories")
}
